---
import { hero } from '../../data/content';
import { cta } from '../../data/brand';
import Button from '../ui/Button.astro';
import StatueCanvas from '../hero/StatueCanvas.astro';
---
<section
  id="top"
  data-hero
  class="relative flex min-h-[100svh] flex-col justify-center overflow-hidden"
>
  <!-- Fond brutal : halo rouge sang + reflet acier sur noir profond. -->
  <div class="hero-fallback absolute inset-0 -z-10" aria-hidden="true"></div>

  {/* Pièce maîtresse WebGL (desktop). Placeholder statue, réactif au curseur. */}
  <StatueCanvas />
  {/* Voile pour garantir la lisibilité du texte par-dessus la 3D. */}
  <div class="hero-veil absolute inset-0 -z-0 hidden lg:block" aria-hidden="true"></div>

  <div class="u-container relative z-10 w-full pt-24 sm:pt-28">
    <p data-hero-fade class="label-mono mb-5 flex items-center gap-3">
      <span class="inline-block h-px w-8 bg-blood-hi sm:w-10"></span>{hero.eyebrow}
    </p>

    <h1 class="display max-w-[56%] leading-[0.85] sm:max-w-none" aria-label={`${hero.titleTop} ${hero.titleBottom}`}>
      <span
        data-hero-chars
        aria-hidden="true"
        class="block text-blood-hi text-[clamp(3rem,12vw,9.5rem)]"
      >{hero.titleTop}</span>
      <span
        data-hero-chars
        aria-hidden="true"
        class="block text-steel-hi text-[clamp(3rem,12vw,9.5rem)]"
      >{hero.titleBottom}</span>
    </h1>

    <div class="mt-7 max-w-[56%] sm:max-w-xl">
      <p data-hero-fade class="tagline text-[clamp(1.5rem,5vw,2.5rem)] text-bone">{hero.baseline}</p>
      <p data-hero-fade class="mt-3 text-sm text-haze/70 sm:text-lg">{hero.sub}</p>
    </div>

    <div data-hero-fade class="mt-9 hidden flex-col gap-3.5 sm:flex-row sm:items-center lg:flex">
      {/* Revue DA : contact immédiat en avant. Appeler (primaire) + Itinéraire. */}
      <Button href={cta.call.href} label={cta.call.label} variant="primary" event="telephone_clic" />
      <Button href={cta.directions.href} label={cta.directions.label} variant="ghost" event="itineraire_clic" />
    </div>
  </div>
</section>

<style>
  /* Halo rouge sang en haut-droite + reflet acier, sur noir profond. */
  .hero-fallback {
    background:
      radial-gradient(
        58% 52% at 82% 26%,
        color-mix(in srgb, var(--color-blood) 38%, transparent),
        transparent 60%
      ),
      radial-gradient(
        70% 60% at 88% 18%,
        color-mix(in srgb, var(--color-blood-deep) 36%, transparent),
        transparent 58%
      ),
      radial-gradient(
        90% 70% at 10% 92%,
        color-mix(in srgb, var(--color-steel-dark) 20%, transparent),
        transparent 55%
      ),
      linear-gradient(155deg, var(--color-ink) 45%, var(--color-surface) 100%);
  }
  /* Dégradé gauche→droite : le texte reste lisible même quand la statue passe
     derrière lui ; la 3D respire dans le tiers droit. */
  .hero-veil {
    background: linear-gradient(
      90deg,
      var(--color-ink) 22%,
      color-mix(in srgb, var(--color-ink) 55%, transparent) 46%,
      transparent 72%
    );
  }
</style>
