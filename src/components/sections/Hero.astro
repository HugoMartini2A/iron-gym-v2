---
import { hero } from '../../data/content';
import GoldButton from '../ui/GoldButton.astro';
---
<section
  id="top"
  data-hero
  class="relative flex min-h-[100svh] flex-col justify-center overflow-hidden"
>
  <!-- Fond brutal : halo rouge sang + reflet acier sur noir profond. -->
  <div class="hero-fallback absolute inset-0 -z-10" aria-hidden="true"></div>
  <!-- Filets acier verticaux (texture « cage »). -->
  <div class="hero-bars pointer-events-none absolute inset-0 -z-10 opacity-[0.06]" aria-hidden="true"></div>

  <div class="u-container relative z-10 pt-28">
    <p data-hero-fade class="label-mono mb-6 flex items-center gap-3">
      <span class="inline-block h-px w-10 bg-blood"></span>{hero.eyebrow}
    </p>

    <h1 class="display leading-[0.8]">
      <span
        data-hero-chars
        class="block text-blood-hi text-[clamp(4.75rem,23vw,18rem)]"
      >{hero.titleTop}</span>
      <span
        data-hero-chars
        class="block text-steel-hi text-[clamp(4.75rem,23vw,18rem)]"
      >{hero.titleBottom}</span>
    </h1>

    <div class="mt-8 max-w-xl">
      <p data-hero-fade class="tagline text-[clamp(1.6rem,5vw,2.5rem)] text-bone">{hero.baseline}</p>
      <p data-hero-fade class="mt-3 text-haze/70">{hero.sub}</p>
    </div>

    <div data-hero-fade class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
      <GoldButton href={hero.cta.href} label={hero.cta.label} variant="primary" objet={hero.cta.objet} />
      <GoldButton href={hero.ctaSecondary.href} label={hero.ctaSecondary.label} variant="ghost" />
    </div>
  </div>

  <!-- Indice de scroll -->
  <div data-hero-fade class="u-container relative z-10 mt-16 flex items-center gap-3 text-haze/40">
    <span class="font-mono text-[0.62rem] uppercase tracking-[0.24em]">Scroll</span>
    <span class="scroll-cue" aria-hidden="true"></span>
  </div>
</section>

<style>
  /* Halo rouge sang en haut-droite + reflet acier, sur noir profond. */
  .hero-fallback {
    background:
      radial-gradient(
        58% 52% at 82% 26%,
        color-mix(in srgb, var(--color-blood) 40%, transparent),
        transparent 60%
      ),
      radial-gradient(
        70% 60% at 88% 18%,
        color-mix(in srgb, var(--color-blood-deep) 38%, transparent),
        transparent 58%
      ),
      radial-gradient(
        90% 70% at 12% 90%,
        color-mix(in srgb, var(--color-steel-dark) 22%, transparent),
        transparent 55%
      ),
      linear-gradient(155deg, var(--color-ink) 45%, var(--color-surface) 100%);
  }
  /* Filets acier verticaux. */
  .hero-bars {
    background-image: repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent 6.5rem,
      var(--color-steel) 6.5rem,
      var(--color-steel) calc(6.5rem + 1px)
    );
  }
  .scroll-cue {
    position: relative;
    display: block;
    height: 36px;
    width: 1px;
    background: color-mix(in srgb, var(--color-steel) 40%, transparent);
    overflow: hidden;
  }
  .scroll-cue::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-blood);
    animation: scroll-cue 2.2s var(--ease-soft) infinite;
  }
  @keyframes scroll-cue {
    0% { transform: translateY(-100%); }
    60%, 100% { transform: translateY(100%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue::after { animation: none; }
  }
</style>
