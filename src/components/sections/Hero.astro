---
import { hero } from '../../data/content';
import GoldButton from '../ui/GoldButton.astro';
---
<section
  id="top"
  data-hero
  class="relative flex min-h-[100svh] flex-col justify-center overflow-hidden"
>
  <!-- Fond brutal : halo rouge sang + reflet acier sur noir profond. -->
  <div class="hero-fallback absolute inset-0 -z-10" aria-hidden="true"></div>

  <div class="u-container relative z-10 w-full pt-24 sm:pt-28">
    <p data-hero-fade class="label-mono mb-5 flex items-center gap-3">
      <span class="inline-block h-px w-8 bg-blood-hi sm:w-10"></span>{hero.eyebrow}
    </p>

    <h1 class="display leading-[0.85]" aria-label={`${hero.titleTop} ${hero.titleBottom}`}>
      <span
        data-hero-chars
        aria-hidden="true"
        class="block text-blood-hi text-[clamp(4rem,20vw,17rem)]"
      >{hero.titleTop}</span>
      <span
        data-hero-chars
        aria-hidden="true"
        class="block text-steel-hi text-[clamp(4rem,20vw,17rem)]"
      >{hero.titleBottom}</span>
    </h1>

    <div class="mt-7 max-w-xl">
      <p data-hero-fade class="tagline text-[clamp(1.5rem,5vw,2.5rem)] text-bone">{hero.baseline}</p>
      <p data-hero-fade class="mt-3 text-base text-haze/70 sm:text-lg">{hero.sub}</p>
    </div>

    <div data-hero-fade class="mt-9 flex flex-col gap-3.5 sm:flex-row sm:items-center">
      <GoldButton href={hero.cta.href} label={hero.cta.label} variant="primary" objet={hero.cta.objet} />
      <GoldButton href={hero.ctaSecondary.href} label={hero.ctaSecondary.label} variant="ghost" />
    </div>
  </div>
</section>

<style>
  /* Halo rouge sang en haut-droite + reflet acier, sur noir profond. */
  .hero-fallback {
    background:
      radial-gradient(
        58% 52% at 82% 26%,
        color-mix(in srgb, var(--color-blood) 38%, transparent),
        transparent 60%
      ),
      radial-gradient(
        70% 60% at 88% 18%,
        color-mix(in srgb, var(--color-blood-deep) 36%, transparent),
        transparent 58%
      ),
      radial-gradient(
        90% 70% at 10% 92%,
        color-mix(in srgb, var(--color-steel-dark) 20%, transparent),
        transparent 55%
      ),
      linear-gradient(155deg, var(--color-ink) 45%, var(--color-surface) 100%);
  }
</style>
