---
import { programs } from '../../data/content';
---
<section id="programmes" class="relative py-[var(--spacing-section)]">
  <div class="u-container">
    <div class="max-w-3xl">
      <h2 data-reveal class="display mt-6 text-[clamp(2rem,4.6vw,3.6rem)] text-haze">
        {programs.title}
      </h2>
      <p data-reveal class="mt-5 max-w-xl text-lg text-haze/70">{programs.intro}</p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        programs.cards.map((card) => (
          <article
            data-reveal
            class="group relative flex h-full flex-col rounded-sm border border-blood/15 bg-surface/60 p-7 transition-colors duration-400 hover:border-blood/50 hover:bg-surface-2"
          >
            {/* Revue DA #13 : numérotation 01/02/03/04 retirée ici aussi. */}
            <h3 class="display text-2xl leading-tight text-haze transition-colors group-hover:text-blood-hi">
              {card.title}
            </h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-haze/65">{card.desc}</p>
            <span class="mt-6 h-px w-10 bg-blood/40 transition-all duration-400 group-hover:w-full" aria-hidden="true" />
          </article>
        ))
      }
    </div>

    <!-- Highlight cours collectifs -->
    <div
      data-reveal
      class="mt-8 flex flex-col items-center gap-4 overflow-hidden rounded-sm border border-blood/15 bg-gradient-to-r from-surface to-surface-2 px-8 py-10 text-center md:flex-row md:justify-between md:text-left"
    >
      <div class="flex items-baseline gap-4">
        <span class="num text-gradient-blood text-[clamp(2.75rem,7vw,5rem)] leading-none">
          {programs.highlight.value}
        </span>
        <span class="font-sans text-xl text-haze/80">{programs.highlight.unit}</span>
      </div>
      <p class="label-mono max-w-md !text-haze/55 !tracking-[0.14em] leading-relaxed">
        {programs.highlight.note}
      </p>
    </div>
  </div>
</section>
