---
import { footer, site } from '../../data/content';
---
<footer class="relative overflow-hidden border-t border-blood/15 pt-12">
  <div class="u-container">
    <div class="flex flex-col gap-8 pb-8 lg:flex-row lg:justify-between">
      <div class="max-w-md">
        <p class="display text-4xl leading-[0.9] text-gradient-blood sm:text-5xl">{site.name}</p>
        <p class="tagline mt-3 text-2xl text-haze/75">{footer.tagline}</p>
        <p class="label-mono mt-4 !text-bronze">{footer.est}</p>
      </div>
    </div>

    <div class="flex flex-col gap-3 border-t border-blood/10 py-5 text-haze/60 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        {
          footer.legal.map((l) => (
            <a href={l.href} class="font-mono text-xs uppercase tracking-widest transition-colors hover:text-blood-hi">
              {l.label}
            </a>
          ))
        }
        <button type="button" data-consent-open class="font-mono text-xs uppercase tracking-widest text-haze/60 transition-colors hover:text-blood-hi">
          Gérer les cookies
        </button>
      </div>
      <p class="font-mono text-xs">
        Site réalisé par <a href="https://cruxstudio.fr" target="_blank" rel="noopener noreferrer" class="text-haze/80 underline underline-offset-2 transition-colors hover:text-blood-hi">cruxstudio.fr</a> · {footer.credit}
      </p>
    </div>
  </div>
</footer>
