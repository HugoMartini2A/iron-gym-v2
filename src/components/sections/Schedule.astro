---
import { schedule } from '../../data/content';

const dayNames = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];

// Icône discrète par discipline (revue DA #16). Tracés simples et lisibles,
// dessinés en trait (stroke). Match par mot-clé, repli = haltère.
const ICONS: Record<string, string> = {
  // Cardio → cœur
  cardio: 'M12 20l-7.1-7.1a4 4 0 0 1 5.7-5.7l1.4 1.4 1.4-1.4a4 4 0 0 1 5.7 5.7z',
  // Tabata / Cross Training → éclair (intensité)
  tabata: 'M13 3 5 13h5l-1 8 8-10h-5z',
  cross: 'M13 3 5 13h5l-1 8 8-10h-5z',
  // Pilates → personne assise (posture)
  pilates: 'M12 4.2a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM12 8v5M6 20c1.8-2.4 3.7-3.4 6-3.4s4.2 1 6 3.4',
  // Bokwa → note de musique (danse)
  bokwa: 'M9 17V5l10-2v12M9 17a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM19 15a2 2 0 1 1-4 0 2 2 0 0 1 4 0z',
  // Body Shake → signal d'activité
  shake: 'M3 12h3.5l2 6 3-12 2 6H21',
  // Body Sculpt / défaut → haltère
  sculpt: 'M4 9v6M7 8v8M17 8v8M20 9v6M7 12h10',
};
const iconFor = (name: string) => {
  const n = name.toLowerCase();
  const key = Object.keys(ICONS).find((k) => n.includes(k));
  return ICONS[key ?? ''] ?? ICONS.sculpt;
};
---
<section id="planning" class="relative py-[var(--spacing-section)]" data-schedule>
  <div class="u-container">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <h2 data-reveal class="display mt-6 text-[clamp(2rem,4.6vw,3.6rem)] text-haze">
          {schedule.title}
        </h2>
        <p data-reveal class="mt-5 max-w-xl text-lg text-haze/70">{schedule.intro}</p>
      </div>
      <p
        data-reveal
        data-week-range
        class="label-mono shrink-0 rounded-full border border-blood/20 px-4 py-2 !text-blood-hi"
      >
        Semaine en cours
      </p>
    </div>

    <!-- Indice de swipe (mobile uniquement) -->
    <p class="mt-8 flex items-center gap-2 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-haze/60 lg:hidden">
      <svg class="h-3.5 w-3.5 text-blood-hi" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 7l-4 5 4 5M16 7l4 5-4 5"/></svg>
      Glissez pour voir chaque jour
    </p>

    <!-- Semaine : swipe horizontal jour par jour sur mobile (snap), grille sur desktop -->
    {/* A7 — Sous 1024px, ce carrousel n'était atteignable qu'au doigt : aucun
        tabindex, aucun enfant focusable, donc totalement inaccessible au
        clavier. `tabindex="0"` rend la piste focusable et défilable aux flèches
        (comportement natif d'un conteneur scrollable ayant le focus). */}
    <div
      data-schedule-track
      tabindex="0"
      role="group"
      aria-label="Planning de la semaine — défilement horizontal sur mobile"
      class="schedule-track mt-3 flex snap-x snap-mandatory gap-3 overflow-x-auto pb-2 lg:mt-12 lg:grid lg:grid-cols-3 lg:overflow-visible lg:pb-0 xl:grid-cols-6"
    >
      {
        schedule.days.map((day, i) => (
          <div
            data-reveal
            data-weekday={i}
            class="schedule-day flex w-[82%] shrink-0 snap-center flex-col rounded-md border border-blood/15 bg-surface/40 p-4 transition-colors sm:w-[46%] lg:w-auto lg:shrink"
          >
            <div class="flex items-baseline justify-between gap-2 border-b border-blood/10 pb-3">
              <span class="display text-lg text-haze">{dayNames[i]}</span>
              <span data-weekday-date class="font-mono text-xs tabular-nums text-haze/60">—</span>
            </div>
            <ul class="mt-3 flex flex-1 flex-col gap-2.5">
              {day.slots.map((slot) => (
                <li class="group/slot rounded-sm bg-ink/40 px-3 py-2.5 transition-all duration-300 hover:-translate-y-0.5 hover:bg-ink/70">
                  <div class="flex items-center gap-2">
                    <svg
                      class="h-4 w-4 shrink-0 text-blood-hi/80 transition-colors group-hover/slot:text-blood-hi"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d={iconFor(slot.name)} />
                    </svg>
                    <span class="font-mono text-xs tabular-nums text-blood-hi">{slot.time}</span>
                  </div>
                  <p class="mt-1 text-sm font-medium text-haze/90">{slot.name}</p>
                  <p class="font-mono text-[0.68rem] uppercase tracking-wide text-haze/55">{slot.coach}</p>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <p class="mt-6 flex items-center gap-2 font-mono text-[0.65rem] uppercase tracking-[0.14em] text-haze/60">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-blood/60" aria-hidden="true"></span>
      {schedule.note}
    </p>
  </div>
</section>

<script>
  // Calcule la semaine courante (lundi → dimanche), remplit les dates et
  // surligne le jour du jour. Aucune dépendance ; tourne aussi en reduced-motion.
  (() => {
    const root = document.querySelector('[data-schedule]');
    if (!root) return;
    const now = new Date();
    const dow = now.getDay(); // 0 = dimanche … 6 = samedi
    const monday = new Date(now);
    monday.setHours(0, 0, 0, 0);
    monday.setDate(now.getDate() + (dow === 0 ? -6 : 1 - dow));

    const fmtDay = (d: Date) =>
      d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }).replace('.', '');
    const sunday = new Date(monday);
    sunday.setDate(monday.getDate() + 6);

    const range = root.querySelector('[data-week-range]');
    if (range) range.textContent = `Semaine du ${fmtDay(monday)} au ${fmtDay(sunday)}`;

    // 0..5 = lun..sam. Dimanche (-1) : aucune colonne → pas de surlignage (repos).
    const todayIndex = dow === 0 ? -1 : dow - 1;

    root.querySelectorAll<HTMLElement>('[data-weekday]').forEach((col) => {
      const i = Number(col.dataset.weekday);
      const date = new Date(monday);
      date.setDate(monday.getDate() + i);
      const cell = col.querySelector('[data-weekday-date]');
      if (cell) cell.textContent = fmtDay(date);
      if (i === todayIndex) col.classList.add('is-today');
      else if (i === todayIndex + 1) col.classList.add('is-tomorrow');
    });

    // Mobile (swipe horizontal) : amène le jour courant dans la vue au chargement.
    const track = root.querySelector<HTMLElement>('[data-schedule-track]');
    const tCol = root.querySelector<HTMLElement>('.schedule-day.is-today');
    if (track && tCol && window.matchMedia('(max-width: 1023px)').matches) {
      track.scrollTo({ left: Math.max(0, tCol.offsetLeft - 16), behavior: 'auto' });
    }
  })();
</script>
