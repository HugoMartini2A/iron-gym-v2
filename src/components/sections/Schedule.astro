---
import { schedule } from '../../data/content';
import SectionLabel from '../ui/SectionLabel.astro';

const dayNames = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];
---
<section id="planning" class="relative py-[var(--spacing-section)]" data-schedule>
  <div class="u-container">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <SectionLabel text={schedule.label} />
        <h2 data-reveal class="display mt-6 text-[clamp(2.25rem,6vw,4.5rem)] text-haze">
          {schedule.title}
        </h2>
        <p data-reveal class="mt-5 max-w-xl text-lg text-haze/70">{schedule.intro}</p>
      </div>
      <p
        data-reveal
        data-week-range
        class="label-mono shrink-0 rounded-full border border-blood/20 px-4 py-2 !text-blood/90"
      >
        Semaine en cours
      </p>
    </div>

    <!-- Indice de swipe (mobile uniquement) -->
    <p class="mt-8 flex items-center gap-2 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-haze/40 lg:hidden">
      <svg class="h-3.5 w-3.5 text-blood" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 7l-4 5 4 5M16 7l4 5-4 5"/></svg>
      Glisse pour voir chaque jour
    </p>

    <!-- Semaine : swipe horizontal jour par jour sur mobile (snap), grille sur desktop -->
    <div
      data-schedule-track
      class="schedule-track mt-3 flex snap-x snap-mandatory gap-3 overflow-x-auto pb-2 lg:mt-12 lg:grid lg:grid-cols-3 lg:overflow-visible lg:pb-0 xl:grid-cols-6"
    >
      {
        schedule.days.map((day, i) => (
          <div
            data-reveal
            data-weekday={i}
            class="schedule-day flex w-[82%] shrink-0 snap-center flex-col rounded-md border border-blood/15 bg-surface/40 p-4 transition-colors sm:w-[46%] lg:w-auto lg:shrink"
          >
            <div class="flex items-baseline justify-between gap-2 border-b border-blood/10 pb-3">
              <span class="display text-lg text-haze">{dayNames[i]}</span>
              <span data-weekday-date class="font-mono text-xs tabular-nums text-haze/45">—</span>
            </div>
            <ul class="mt-3 flex flex-1 flex-col gap-2.5">
              {day.slots.map((slot) => (
                <li class="group/slot rounded-sm bg-ink/40 px-3 py-2.5 transition-colors hover:bg-ink/70">
                  <div class="flex items-center justify-between gap-2">
                    <span class="font-mono text-xs tabular-nums text-blood">{slot.time}</span>
                  </div>
                  <p class="mt-0.5 text-sm font-medium text-haze/90">{slot.name}</p>
                  <p class="font-mono text-[0.68rem] uppercase tracking-wide text-haze/40">{slot.coach}</p>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <p class="mt-6 flex items-center gap-2 font-mono text-[0.65rem] uppercase tracking-[0.14em] text-haze/35">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-blood/60" aria-hidden="true"></span>
      {schedule.note}
    </p>
  </div>
</section>

<script>
  // Calcule la semaine courante (lundi → dimanche), remplit les dates et
  // surligne le jour du jour. Aucune dépendance ; tourne aussi en reduced-motion.
  (() => {
    const root = document.querySelector('[data-schedule]');
    if (!root) return;
    const now = new Date();
    const dow = now.getDay(); // 0 = dimanche … 6 = samedi
    const monday = new Date(now);
    monday.setHours(0, 0, 0, 0);
    monday.setDate(now.getDate() + (dow === 0 ? -6 : 1 - dow));

    const fmtDay = (d: Date) =>
      d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }).replace('.', '');
    const sunday = new Date(monday);
    sunday.setDate(monday.getDate() + 6);

    const range = root.querySelector('[data-week-range]');
    if (range) range.textContent = `Semaine du ${fmtDay(monday)} au ${fmtDay(sunday)}`;

    // 0..5 = lun..sam. Dimanche (-1) : aucune colonne → pas de surlignage (repos).
    const todayIndex = dow === 0 ? -1 : dow - 1;

    root.querySelectorAll<HTMLElement>('[data-weekday]').forEach((col) => {
      const i = Number(col.dataset.weekday);
      const date = new Date(monday);
      date.setDate(monday.getDate() + i);
      const cell = col.querySelector('[data-weekday-date]');
      if (cell) cell.textContent = fmtDay(date);
      if (i === todayIndex) col.classList.add('is-today');
    });

    // Mobile (swipe horizontal) : amène le jour courant dans la vue au chargement.
    const track = root.querySelector<HTMLElement>('[data-schedule-track]');
    const tCol = root.querySelector<HTMLElement>('.schedule-day.is-today');
    if (track && tCol && window.matchMedia('(max-width: 1023px)').matches) {
      track.scrollTo({ left: Math.max(0, tCol.offsetLeft - 16), behavior: 'auto' });
    }
  })();
</script>
