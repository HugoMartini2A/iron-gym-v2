---
/**
 * HERO — pièce maîtresse WebGL temps réel (revue DA, direction « Lusion »).
 * ----------------------------------------------------------------------------
 * Une FIGURE MASCULINE chromée en pose (esprit statue antique / most-muscular),
 * construite en primitives, qui tourne lentement et réagit au curseur sous un
 * éclairage studio. C'est un PLACEHOLDER stylisé : dès qu'on a un vrai modèle de
 * statue, il suffit de déposer `public/statue.glb` — le chargeur ci-dessous le
 * détecte et remplace la figure automatiquement.
 *
 * Garde-fous perf (points 22-23) : three en import() dynamique sur idle (hors
 * chemin critique / LCP), rendu en pause hors écran, DPR plafonné, masqué mobile,
 * reduced-motion → 1 frame statique.
 */
---

<div
  data-statue
  class="statue-mount pointer-events-none absolute inset-y-0 right-0 -z-0 w-[54%] lg:w-[52%]"
  aria-hidden="true"
>
  <canvas data-statue-canvas class="h-full w-full"></canvas>
</div>

<script>
  const mount = document.querySelector<HTMLElement>('[data-statue]');
  const canvas = document.querySelector<HTMLCanvasElement>('[data-statue-canvas]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // Statue active aussi sur mobile (demande client). Perf préservée par : DPR
  // plafonné plus bas sur mobile, pause hors-écran (IntersectionObserver),
  // reduced-motion (1 frame), boot sur idle. Seul garde-fou restant : un GPU.
  const enabled = !!mount && !!canvas && !!(window as unknown as { WebGLRenderingContext?: unknown }).WebGLRenderingContext;

  const boot = () => {
    if (!enabled || !mount || !canvas) return;

    import('three').then(async (THREE) => {
      const { RoomEnvironment } = await import(
        'three/examples/jsm/environments/RoomEnvironment.js'
      );

      const renderer = new THREE.WebGLRenderer({
        canvas, antialias: true, alpha: true, powerPreference: 'high-performance',
      });
      const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
      // DPR plafonné plus bas sur mobile (moins de pixels à calculer) → la statue
      // tourne sans plomber les perfs sur téléphone.
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, isDesktop ? 2 : 1.5));
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.1;

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(36, 1, 0.1, 100);
      camera.position.set(0, 0, 9);

      const pmrem = new THREE.PMREMGenerator(renderer);
      scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

      // Matériau acier poli commun (chrome sombre, très réfléchissant).
      const metal = new THREE.MeshStandardMaterial({
        color: 0x8b9198, metalness: 1.0, roughness: 0.16, envMapIntensity: 1.4,
      });

      // ── Construction de la figure en pose ────────────────────────────────
      const figure = new THREE.Group();
      const part = (
        geo: import('three').BufferGeometry,
        x: number, y: number, z: number,
        rx = 0, ry = 0, rz = 0, s = 1,
      ) => {
        const m = new THREE.Mesh(geo, metal);
        m.position.set(x, y, z);
        m.rotation.set(rx, ry, rz);
        m.scale.setScalar(s);
        figure.add(m);
        return m;
      };
      const cap = (r: number, len: number) =>
        new THREE.CapsuleGeometry(r, len, 10, 22);
      const sph = (r: number) => new THREE.SphereGeometry(r, 32, 24);

      // ── Pose « Victoire » (réf. classic physique) : bras gauche levé en V,
      //    bras droit en biceps, appui contrapposto. Musculature DÉTAILLÉE
      //    (pecs, abdos, obliques, biceps, quads, mollets) pour sortir du
      //    « bibendum » → registre chrome façon Surfer d'Argent. ──

      const musc = (r: number, x: number, y: number, z: number, sx = 1, sy = 1, sz = 1) => {
        const m = part(sph(r), x, y, z);
        m.scale.set(sx, sy, sz);
        return m;
      };

      // Tête (mâchoire) + cou + trapèzes
      const head = part(sph(0.26), -0.04, 1.78, 0.03);
      head.scale.set(0.8, 1.02, 0.86);
      part(cap(0.1, 0.2), 0, 1.5, 0);
      musc(0.3, 0, 1.34, -0.02, 1.35, 0.46, 0.7); // trapèzes

      // Cage thoracique + pectoraux (masses enfoncées, pas des billes séparées)
      musc(0.54, 0, 1.0, 0.05, 1.24, 0.86, 0.66); // cage (base large et lisse)
      musc(0.24, -0.22, 1.02, 0.28, 1.0, 0.66, 0.66); // pec G
      musc(0.24, 0.22, 1.02, 0.28, 1.0, 0.66, 0.66); // pec D

      // Abdominaux : deux colonnes de trois, subtils (peu de relief)
      [0.64, 0.46, 0.28].forEach((y) => {
        musc(0.095, -0.12, y, 0.28, 1, 0.78, 0.55);
        musc(0.095, 0.12, y, 0.28, 1, 0.78, 0.55);
      });
      musc(0.38, 0, 0.3, 0.02, 0.92, 0.78, 0.56); // ventre/obliques (masse lisse)
      musc(0.34, 0, 0.16, 0, 0.86, 0.7, 0.5); // taille (V-taper)

      // Deltoïdes
      musc(0.25, -0.7, 1.26, 0.04);
      musc(0.26, 0.72, 1.26, 0.04);

      // BRAS GAUCHE levé en V, biceps bombé, main ouverte au sommet
      part(cap(0.13, 0.5), -1.0, 1.7, 0.02, 0, 0, 0.55);
      musc(0.16, -0.92, 1.56, 0.06); // renflement biceps
      part(cap(0.1, 0.46), -1.24, 2.22, 0.04, 0, 0, 0.24);
      const handL = part(sph(0.15), -1.33, 2.62, 0.05);
      handL.scale.set(0.9, 1.15, 0.5);

      // BRAS DROIT biceps de profil, contracté
      part(cap(0.13, 0.44), 1.12, 1.22, 0.05, 0, 0, -1.45);
      musc(0.17, 1.18, 1.36, 0.09); // biceps contracté (pic)
      part(cap(0.11, 0.4), 1.42, 1.62, 0.06, 0, 0, -0.12);
      part(sph(0.13), 1.38, 1.94, 0.06); // poing

      // Bassin + jambes contrapposto, quadriceps et mollets définis
      musc(0.36, 0, 0.05, 0, 1, 0.66, 0.56); // bassin
      part(cap(0.16, 0.64), -0.25, -0.62, -0.02, 0, 0, 0.03); // fémur G (appui)
      musc(0.19, -0.27, -0.5, 0.16, 0.82, 1.05, 0.72); // quad G
      part(cap(0.155, 0.58), 0.26, -0.6, 0.12, 0.12, 0, -0.05); // fémur D
      musc(0.18, 0.29, -0.48, 0.28, 0.82, 1.05, 0.72); // quad D
      part(cap(0.13, 0.6), -0.28, -1.34, -0.02); // tibia G
      musc(0.15, -0.31, -1.16, 0.08, 0.82, 1.2, 0.7); // mollet G
      part(cap(0.12, 0.56), 0.31, -1.3, 0.16, 0.1, 0, 0); // tibia D
      musc(0.14, 0.34, -1.12, 0.24, 0.82, 1.2, 0.7); // mollet D

      figure.position.y = -0.2;
      figure.scale.setScalar(0.98);
      // NE PAS ajouter la figure primitive tout de suite : elle ne sert que de
      // SECOURS si le vrai modèle échoue. Sinon elle « flashait » ~500 ms avant
      // que le .glb arrive. Le hero reste sobre pendant le court chargement.
      let subject: import('three').Object3D = figure;
      let subjectSize: import('three').Vector3 | null = null;

      // Cadre le sujet pour qu'il tienne ENTIÈREMENT dans le canvas (jamais rogné
      // sur les côtés), en tenant compte du ratio du canvas — étroit sur mobile.
      const frameSubject = () => {
        if (!subjectSize || subject === figure) return;
        const vExt = 2 * Math.tan((camera.fov * Math.PI) / 360) * camera.position.z;
        const hExt = vExt * camera.aspect;
        subject.scale.setScalar(0.85 * Math.min(vExt / subjectSize.y, hExt / subjectSize.x));
      };

      // Si un vrai modèle est déposé, il remplace la figure placeholder.
      // On essaie plusieurs emplacements — selon ce que Sketchfab produit :
      //   • un .glb unique         → public/statue.glb
      //   • un dossier glTF dézippé → public/statue/scene.gltf
      import('three/examples/jsm/loaders/GLTFLoader.js')
        .then(async ({ GLTFLoader }) => {
          const loader = new GLTFLoader();
          // Décodeur meshopt : permet de charger un .glb compressé (EXT_meshopt).
          // Sans compression, sans effet — le .gltf non compressé charge pareil.
          try {
            const { MeshoptDecoder } = await import(
              'three/examples/jsm/libs/meshopt_decoder.module.js'
            );
            loader.setMeshoptDecoder(MeshoptDecoder);
          } catch {
            /* décodeur indisponible → modèle non compressé uniquement */
          }
          const candidates = ['/statue.glb', '/statue/scene.gltf', '/statue.gltf'];
          const onLoaded = (gltf: { scene: import('three').Object3D }) => {
            gltf.scene.traverse((o) => {
              const mesh = o as import('three').Mesh;
              if (mesh.isMesh) mesh.material = metal; // acier chromé imposé
            });
            // Recentre le modèle dans un groupe ; l'échelle est gérée par
            // frameSubject (contain, selon le ratio du canvas) → jamais rogné.
            const box = new THREE.Box3().setFromObject(gltf.scene);
            subjectSize = box.getSize(new THREE.Vector3());
            gltf.scene.position.sub(box.getCenter(new THREE.Vector3()));
            const holder = new THREE.Group();
            holder.add(gltf.scene);
            scene.remove(figure);
            scene.add(holder);
            subject = holder;
            frameSubject();
          };
          const tryLoad = (i: number) => {
            if (i >= candidates.length) {
              // Aucun modèle chargeable : on NE montre PAS la figure primitive
              // (rejetée par le client). Le hero garde son fond dégradé, sans statue.
              return;
            }
            loader.load(candidates[i], onLoaded, undefined, () => tryLoad(i + 1));
          };
          tryLoad(0);
        })
        .catch(() => {
          /* three/GLTFLoader indisponible : pas de figure primitive de secours. */
        });

      // Lumières : appoint froid + jante rouge sang (rappel de marque).
      const key = new THREE.DirectionalLight(0xffffff, 2.0);
      key.position.set(3, 4, 5);
      scene.add(key);
      const rim = new THREE.DirectionalLight(0xc0392b, 3.6);
      rim.position.set(-5, 0, -3);
      scene.add(rim);
      scene.add(new THREE.AmbientLight(0x181820, 1));

      const target = { x: 0, y: 0 };
      const cur = { x: 0, y: 0 };
      const onPointer = (e: PointerEvent) => {
        target.x = (e.clientX / window.innerWidth - 0.5) * 2;
        target.y = (e.clientY / window.innerHeight - 0.5) * 2;
      };
      if (!reduced) window.addEventListener('pointermove', onPointer, { passive: true });

      const resize = () => {
        const r = mount.getBoundingClientRect();
        if (r.width < 2 || r.height < 2) return;
        renderer.setSize(r.width, r.height, false);
        camera.aspect = r.width / r.height;
        camera.updateProjectionMatrix();
        frameSubject();
      };
      resize();
      new ResizeObserver(resize).observe(mount);

      let visible = true;
      new IntersectionObserver(
        ([entry]) => {
          visible = entry.isIntersecting;
          if (visible && !reduced) loop();
        },
        { threshold: 0.01 },
      ).observe(mount);

      const clock = new THREE.Clock();
      let raf = 0;
      const render = () => {
        const t = clock.getElapsedTime();
        cur.x += (target.x - cur.x) * 0.045;
        cur.y += (target.y - cur.y) * 0.045;
        subject.rotation.y = t * 0.09 + cur.x * 0.5;
        subject.rotation.x = cur.y * 0.18;
        // Abaissée légèrement (−0.4) pour dégager la tête de l'en-tête fixe.
        subject.position.y = (subject === figure ? -0.2 : -0.4) + Math.sin(t * 0.6) * 0.06;
        renderer.render(scene, camera);
      };
      const loop = () => {
        cancelAnimationFrame(raf);
        const tick = () => {
          render();
          if (visible && !reduced) raf = requestAnimationFrame(tick);
        };
        tick();
      };
      if (reduced) render();
      else loop();
    });
  };

  // Démarrage prompt et à démarrage unique : la statue est la pièce maîtresse
  // du hero, elle ne doit pas « manquer » les premières secondes. On lance dès
  // que le thread respire (idle court), avec plusieurs filets de sécurité si
  // l'onglet est occupé (setTimeout + load) pour qu'elle apparaisse toujours.
  let started = false;
  const start = () => {
    if (started) return;
    started = true;
    boot();
  };
  const ric = (window as unknown as { requestIdleCallback?: (cb: () => void, o?: { timeout: number }) => void })
    .requestIdleCallback;
  if (ric) ric(start, { timeout: 600 });
  else setTimeout(start, 150);
  if (document.readyState === 'complete') setTimeout(start, 300);
  else window.addEventListener('load', () => setTimeout(start, 300));
</script>
