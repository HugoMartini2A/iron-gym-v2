---
/**
 * Affiche une image réelle (optimisée par Astro <Image> → WebP responsive)
 * OU, tant que `src` est null, un bloc placeholder étiqueté.
 * Réserve toujours la place via aspect-ratio → zéro CLS.
 *
 * RÉGIMES (lot A5) — le traitement tonal est gravé dans les fichiers, pas
 * appliqué au runtime. `regime` ne fait que choisir le cadre et le voile :
 *   • 'present' (défaut) → N&B contrasté, voile de pied pour asseoir sur #0A0A0A
 *   • 'archive'          → sépia délavé, liseré papier, tout l'avant-2018
 * Les deux ne se mélangent jamais dans un même cadre (cf. BLUEPRINT-V2 §5.2).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Media } from '../../data/content';

interface Props {
  media: Media;
  class?: string;
  eager?: boolean;
  regime?: 'present' | 'archive' | 'golden';
}
const { media, class: className = '', eager = false, regime = 'present' } = Astro.props;
const ratio = media.ratio ?? '4/5';

// Mappe les chemins de content.ts (/images/x.webp) vers les assets importés
// (src/assets/images) pour qu'Astro les optimise au build.
const assets = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/*.webp',
  { eager: true },
);
const resolved: ImageMetadata | null = media.src
  ? (() => {
      const base = media.src.split('/').pop();
      const key = Object.keys(assets).find((k) => k.endsWith('/' + base));
      return key ? assets[key].default : null;
    })()
  : null;
---

<figure
  class={`media-wrap relative isolate overflow-hidden ${className}`}
  style={`aspect-ratio:${ratio}`}
>
  {
    resolved ? (
      <Image
        src={resolved}
        alt={media.alt}
        class={`img-${regime} h-full w-full object-cover`}
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        quality={68}
      />
    ) : (
      <div class="placeholder-media h-full w-full" role="img" aria-label={media.alt}>
        <div class="godrays pointer-events-none absolute inset-0 opacity-40"></div>
        <div class="relative z-10 max-w-[80%] px-6 text-center">
          <svg
            class="mx-auto mb-3 h-7 w-7 text-blood-hi"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            aria-hidden="true"
          >
            <rect x="3" y="6" width="18" height="13" rx="2" />
            <circle cx="12" cy="12.5" r="3.2" />
            <path d="M8 6l1.2-2h5.6L16 6" />
          </svg>
          <p class="label-mono !text-blood-hi leading-relaxed">{media.placeholder}</p>
        </div>
      </div>
    )
  }
</figure>
