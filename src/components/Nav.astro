---
import { nav, cta } from '../data/brand';
import { site } from '../data/site';
import { contact } from '../data/contact';
// Sérialisé pour le statut live. Source = ACCÈS SALLE (contact.accessHours, 6h–23h
// 7j/7), PAS l'accueil staff — le header reflète quand la salle est accessible.
const hoursJson = JSON.stringify(contact.accessHours);

// CTA contact du header (revue DA) : Instagram + appel direct.
const instagram = contact.socials.find((s) => s.label === 'Instagram')?.href ?? '#';
const telHref = `tel:${contact.phone.tel}`;

// One-page : sur la home, les ancres défilent (smooth Lenis). Sur les pages
// légales, on préfixe par « / » pour revenir à la home puis défiler.
const onHome = Astro.url.pathname === '/';
const toSection = (href: string) => (onHome ? href : `/${href}`);
---
<header data-nav class="fixed inset-x-0 top-0 z-50">
  <nav
    class="u-container flex items-center justify-between gap-3 py-3.5"
    aria-label="Navigation principale"
  >
    <!-- Marque (logo + wordmark) + statut live -->
    <div class="flex min-w-0 items-center gap-2.5">
      <a href="/" class="flex items-center gap-2.5" aria-label={`${site.name} — accueil`}>
        <img
          src="/logo-iron-gym.webp"
          alt={site.name}
          width="40"
          height="40"
          class="h-9 w-9 rounded-md object-cover ring-1 ring-blood/40 sm:h-10 sm:w-10"
        />
        <span class="display hidden text-lg tracking-wide text-haze transition-colors hover:text-blood-hi sm:inline sm:text-xl">
          Iron Gym<span class="text-blood-hi">.</span>
        </span>
      </a>
      <span
        data-open-status
        data-hours={hoursJson}
        hidden
        aria-live="polite"
        class="open-status ml-1 hidden sm:inline-flex"
      >
        <span class="open-status__dot" aria-hidden="true"></span>
        <span class="open-status__word" data-open-word></span>
        <span class="open-status__detail" data-open-detail></span>
      </span>
    </div>

    <!-- Liens (centre, desktop) — tracking resserré pour lire les libellés
         longs comme des mots, pas des lettres espacées. -->
    <ul class="hidden items-center gap-6 lg:flex xl:gap-8">
      {
        nav.map((link) => (
          <li>
            <a
              href={toSection(link.href)}
              class="hover-underline whitespace-nowrap font-mono text-[0.8rem] font-medium uppercase tracking-[0.06em] text-haze/75 transition-colors hover:text-blood-hi"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA (desktop) + burger (mobile) -->
    <div class="flex items-center gap-2 lg:pl-3">
      {/* Contacts directs — Instagram + appel. Petits, groupés, séparés du CTA. */}
      <a
        href={instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Iron Gym sur Instagram"
        class="nav-icon hidden h-10 w-10 items-center justify-center rounded-full border border-steel/20 text-haze/70 transition-all hover:-translate-y-0.5 hover:border-blood hover:text-blood-hi lg:inline-flex"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" />
          <circle cx="12" cy="12" r="4" />
          <circle cx="17.4" cy="6.6" r="1" fill="currentColor" stroke="none" />
        </svg>
      </a>
      <a
        href={telHref}
        aria-label="Appeler Iron Gym"
        data-event="telephone_clic"
        data-section="nav"
        class="nav-icon hidden h-10 w-10 items-center justify-center rounded-full border border-steel/20 text-haze/70 transition-all hover:-translate-y-0.5 hover:border-blood hover:text-blood-hi lg:inline-flex"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 4h3l1.5 4-2 1.4a11 11 0 0 0 5 5l1.4-2 4 1.5v3a1 1 0 0 1-1 1A16 16 0 0 1 4 5a1 1 0 0 1 1-1z" />
        </svg>
      </a>
      {/* Header : libellé court « Réserver » pour désengorger. Le libellé
          complet « Réserver ma première séance » reste dans les sections. */}
      <a
        href={toSection(cta.primary.href)}
        data-magnetic="0.25"
        data-event="cta_premiere_seance"
        data-section="nav"
        class="ml-1 hidden min-h-[44px] items-center rounded-full bg-blood px-5 py-2.5 font-mono text-xs font-medium uppercase tracking-[0.12em] text-bone transition-colors hover:bg-blood-hi lg:inline-flex"
      >
        Prendre contact
      </a>
      <button
        type="button"
        data-nav-toggle
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="nav-burger inline-flex h-11 w-11 items-center justify-center rounded-full border border-blood/30 text-blood-hi transition-colors hover:border-blood hover:bg-blood/10 lg:hidden"
      >
        <span class="nav-burger__box" aria-hidden="true">
          <span class="nav-burger__line"></span>
          <span class="nav-burger__line"></span>
          <span class="nav-burger__line"></span>
        </span>
      </button>
    </div>
  </nav>

  <!-- Barre de progression de scroll + haltère (remplie au scroll) — tous viewports -->
  <div data-scroll-progress class="scroll-progress" aria-hidden="true">
    <span data-scroll-progress-fill class="scroll-progress__fill"></span>
    <span data-scroll-progress-thumb class="scroll-progress__thumb">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <rect x="11" y="2.5" width="2" height="19" rx="0.4" />
        <rect x="9.2" y="3" width="5.6" height="1.7" rx="0.5" />
        <rect x="7.6" y="5.2" width="8.8" height="1.9" rx="0.5" />
        <rect x="6.2" y="7.6" width="11.6" height="2.1" rx="0.6" />
        <rect x="6.2" y="14.3" width="11.6" height="2.1" rx="0.6" />
        <rect x="7.6" y="16.9" width="8.8" height="1.9" rx="0.5" />
        <rect x="9.2" y="19.3" width="5.6" height="1.7" rx="0.5" />
      </svg>
    </span>
  </div>

  <!-- Menu plein écran (mobile) -->
  <div id="mobile-menu" data-nav-menu hidden class="mobile-menu lg:hidden" aria-label="Menu">
    <div class="u-container">
      <div class="mb-8 flex items-center gap-3">
        <img src="/logo-iron-gym.webp" alt="" width="44" height="44" class="h-11 w-11 rounded-md object-cover ring-1 ring-blood/40" />
        <span class="display text-xl tracking-wide text-haze">Iron Gym<span class="text-blood-hi">.</span></span>
      </div>
      <ul class="mobile-menu__list">
        {
          nav.map((link) => (
            <li>
              <a href={toSection(link.href)} data-nav-link class="mobile-menu__link display text-haze transition-colors hover:text-blood-hi">
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="mt-4">
          <a
            href={toSection(cta.primary.href)}
            data-event="cta_premiere_seance"
            data-section="nav-mobile"
            data-nav-link
            class="inline-flex min-h-[48px] items-center rounded-full bg-blood px-6 py-3 font-mono text-sm uppercase tracking-[0.14em] text-bone transition-colors hover:bg-blood-hi"
          >
            {cta.primary.label}
          </a>
        </li>
        {/* Actions directes mobile — pour un commerce local, l'appel est l'action
            n°1 : elle n'était joignable nulle part dans l'en-tête/menu mobile
            (icônes tél/insta en lg: uniquement). Ajoutées ici, tap-to-call en tête. */}
        <li class="mt-7 flex items-center gap-3 border-t border-blood/15 pt-7">
          <a
            href={telHref}
            data-event="telephone_clic"
            data-section="nav-mobile"
            class="inline-flex min-h-[52px] flex-1 items-center justify-center gap-2.5 rounded-full border border-steel/30 px-5 font-mono text-sm uppercase tracking-[0.12em] text-haze transition-colors hover:border-blood hover:text-blood-hi"
          >
            <svg class="h-5 w-5 text-blood-hi" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 4h3l1.5 4-2 1.4a11 11 0 0 0 5 5l1.4-2 4 1.5v3a1 1 0 0 1-1 1A16 16 0 0 1 4 5a1 1 0 0 1 1-1z" />
            </svg>
            Appeler
          </a>
          <a
            href={instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Iron Gym sur Instagram"
            class="inline-flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-full border border-steel/30 text-haze transition-colors hover:border-blood hover:text-blood-hi"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.4" cy="6.6" r="1" fill="currentColor" stroke="none" />
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  // Statut « Ouvert / Fermé » en direct, calculé à l'HEURE DE PARIS, à partir de
  // l'ACCÈS SALLE 6h–23h 7j/7 (sérialisé dans data-hours).
  (() => {
    const el = document.querySelector<HTMLElement>('[data-open-status]');
    if (!el) return;
    type Range = [string, string];
    let hours: { day: string; ranges: Range[] }[] = [];
    try {
      hours = JSON.parse(el.dataset.hours || '[]');
    } catch {
      return;
    }
    if (!hours.length) return;

    const wordEl = el.querySelector<HTMLElement>('[data-open-word]');
    const detailEl = el.querySelector<HTMLElement>('[data-open-detail]');
    const EN_TO_IDX: Record<string, number> = {
      Mon: 0, Tue: 1, Wed: 2, Thu: 3, Fri: 4, Sat: 5, Sun: 6,
    };
    const toMin = (hm: string) => {
      const [h, m] = hm.split(':').map(Number);
      return h * 60 + m;
    };
    const fmt = (hm: string) => hm.replace(':', 'h');

    const update = () => {
      const parts = new Intl.DateTimeFormat('en-US', {
        timeZone: 'Europe/Paris',
        weekday: 'short',
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
      }).formatToParts(new Date());
      const wd = parts.find((p) => p.type === 'weekday')?.value ?? 'Mon';
      const hour = Number(parts.find((p) => p.type === 'hour')?.value ?? '0') % 24;
      const minute = Number(parts.find((p) => p.type === 'minute')?.value ?? '0');
      const dayIdx = EN_TO_IDX[wd] ?? 0;
      const nowMin = hour * 60 + minute;

      const today = hours[dayIdx]?.ranges ?? [];
      let open = false;
      let closeAt = '';
      for (const [a, b] of today) {
        if (nowMin >= toMin(a) && nowMin < toMin(b)) {
          open = true;
          closeAt = b;
          break;
        }
      }

      let detail = '';
      if (open) {
        detail = ` · ferme à ${fmt(closeAt)}`;
      } else {
        let nextOpen = '';
        let when = '';
        for (const [a] of today) {
          if (toMin(a) > nowMin) {
            nextOpen = a;
            when = "aujourd'hui";
            break;
          }
        }
        if (!nextOpen) {
          for (let i = 1; i <= 7; i++) {
            const d = hours[(dayIdx + i) % 7];
            if (d && d.ranges.length) {
              nextOpen = d.ranges[0][0];
              when = i === 1 ? 'demain' : d.day.toLowerCase();
              break;
            }
          }
        }
        detail = nextOpen ? ` · ouvre ${when} à ${fmt(nextOpen)}` : '';
      }

      el.classList.toggle('is-open', open);
      el.classList.toggle('is-closed', !open);
      if (wordEl) wordEl.textContent = open ? 'Ouvert' : 'Fermé';
      if (detailEl) detailEl.textContent = detail;
      el.setAttribute('aria-label', `${open ? 'Ouvert' : 'Fermé'}${detail}`);
      el.hidden = false;
    };

    update();
    window.setInterval(update, 60_000);
  })();
</script>
