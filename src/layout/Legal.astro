---
import '../styles/global.css';

import { site, footer } from '../data/content';
import Grain from '../components/Grain.astro';
import ConsentBanner from '../components/ConsentBanner.astro';

interface Props {
  title: string;
  description: string;
  /** Date de dernière mise à jour affichée en tête (ex. « Juin 2026 »). */
  updated?: string;
}
const { title, description, updated } = Astro.props;
const fullTitle = `${title} — ${site.name}`;
const canonical = new URL(Astro.url.pathname, site.url).href;
---
<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content={site.themeColor} />
    <link rel="preload" href="/fonts/teko-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dmsans-400.woff2" as="font" type="font/woff2" crossorigin />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
  </head>

  <body class="vignette min-h-screen">
    <Grain />

    <header class="border-b border-blood/10">
      <div class="u-container flex items-center justify-between py-5">
        <a href="/#top" class="display text-xl tracking-wide text-haze transition-colors hover:text-blood-hi">
          {site.shortName}<span class="text-blood-hi">.</span>
        </a>
        <a href="/" class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.16em] text-haze/70 transition-colors hover:text-blood-hi">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
          Retour au site
        </a>
      </div>
    </header>

    <main class="u-container py-16 sm:py-24">
      <div class="mx-auto max-w-3xl">
        <!-- Bandeau : document modèle -->
        <p class="mb-8 rounded-md border border-rust/30 bg-rust/10 px-4 py-3 font-mono text-xs uppercase tracking-[0.12em] text-rust">
          ⚠ Document modèle — à faire valider par un juriste avant mise en ligne.
        </p>

        <p class="label-mono">Iron Gym Limoges</p>
        <h1 class="display mt-4 text-[clamp(2rem,7vw,3.75rem)] text-gradient-blood">{title}</h1>
        {updated && (
          <p class="mt-3 font-mono text-xs uppercase tracking-widest text-haze/60">
            Dernière mise à jour : {updated}
          </p>
        )}

        <div class="legal-prose mt-12">
          <slot />
        </div>
      </div>
    </main>

    <footer class="border-t border-blood/10">
      <div class="u-container flex flex-col gap-4 py-8 text-haze/60 md:flex-row md:items-center md:justify-between">
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          {footer.legal.map((l) => (
            <a href={l.href} class="font-mono text-xs uppercase tracking-widest transition-colors hover:text-blood-hi">
              {l.label}
            </a>
          ))}
          <button type="button" data-consent-open class="font-mono text-xs uppercase tracking-widest text-haze/60 transition-colors hover:text-blood-hi">
            Gérer les cookies
          </button>
        </div>
        <p class="font-mono text-xs">
          Site réalisé par <a href="https://cruxstudio.fr" target="_blank" rel="noopener noreferrer" class="text-haze/80 underline underline-offset-2 transition-colors hover:text-blood-hi">cruxstudio.fr</a> · {footer.credit}
        </p>
      </div>
    </footer>
    <ConsentBanner />

    <style>
      .legal-prose :global(h2) {
        font-family: var(--font-display);
        text-transform: uppercase;
        letter-spacing: 0.005em;
        /* Leading généreux : les accents d'Anton (É È…) ne sont jamais rognés. */
        line-height: 1.2;
        padding-block: 0.06em;
        font-size: clamp(1.4rem, 3.5vw, 2rem);
        color: var(--color-haze);
        margin-top: 2.75rem;
        margin-bottom: 1rem;
        padding-bottom: 0.6rem;
        border-bottom: 1px solid color-mix(in srgb, var(--color-blood) 18%, transparent);
      }
      .legal-prose :global(h3) {
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.8rem;
        color: var(--color-blood);
        margin-top: 2rem;
        margin-bottom: 0.5rem;
      }
      .legal-prose :global(p),
      .legal-prose :global(li) {
        color: color-mix(in srgb, var(--color-haze) 78%, transparent);
        line-height: 1.7;
      }
      .legal-prose :global(p) {
        margin-block: 0.9rem;
      }
      .legal-prose :global(ul) {
        margin-block: 0.9rem;
        padding-left: 1.1rem;
        list-style: none;
      }
      .legal-prose :global(li) {
        position: relative;
        padding-left: 1rem;
        margin-block: 0.4rem;
      }
      .legal-prose :global(li)::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.7em;
        width: 0.4rem;
        height: 1px;
        background: var(--color-blood);
      }
      .legal-prose :global(strong) {
        color: var(--color-bone);
        font-weight: 600;
      }
      .legal-prose :global(a) {
        color: var(--color-blood);
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .legal-prose :global(.todo) {
        color: var(--color-rust);
        font-family: var(--font-mono);
        font-size: 0.85em;
      }
    </style>
  </body>
</html>
